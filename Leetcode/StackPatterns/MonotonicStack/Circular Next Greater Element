class Solution {
    public int[] nextGreaterElements(int[] nums) {
        int n = nums.length;
        int[] result = new int[nums.length];
        Stack<Integer>stk = new Stack<>();
Arrays.fill(result,-1);
        for(int i = 0;i<2*n;i++){
            int index = i % n;
    while(!stk.isEmpty() && nums[stk.peek()]<nums[index]){
        result[stk.pop()]=nums[index];
    }
    if(i<n){
        stk.push(index);
    }
        }
        return result;
    }
}
